# Copy this file to your private env location, for example:
# C:\Users\<you>\secrets\ai-trading-gold\.env
#
# Do not commit real values. config/settings.py loads env files in this order:
# 1. GOLD_ENV_PATH
# 2. C:\Users\<you>\secrets\ai-trading-gold\.env
# 3. .env in the project root

# Broker / Capital.com
CAPITAL_EMAIL=your-email@example.com
CAPITAL_PASSWORD=replace-with-your-password
CAPITAL_API_KEY=replace-with-your-api-key
CAPITAL_DEMO=true

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gold_trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=replace-with-a-local-password
SQLITE_FALLBACK=true

# Trading safety defaults
TRADING_MODE=semi_auto
MAX_RISK_PER_TRADE_PCT=0.5
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=1
MAX_TRADES_PER_DAY=5

# API
API_ENABLED=true
API_HOST=127.0.0.1
API_PORT=8000
API_AUTH_ENABLED=true
API_KEY=replace-with-a-long-random-local-key
CORS_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:5173

# Notifications
NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Optional features
MIROFISH_ENABLED=false
CALENDAR_ENABLED=true
